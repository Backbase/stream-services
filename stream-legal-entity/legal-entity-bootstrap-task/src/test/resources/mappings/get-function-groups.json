{
  "request": {
    "method": "GET",
    "urlPath": "/access-control/service-api/v1/access-control/function-groups",
    "headers": {
      "traceparent": {
        "matches": "00-[0-9a-f]{32}-[0-9a-f]{16}-[0-9a-f]{2}"
      },
      "X-TID": {
        "contains": "tenant1"
      }
    },
    "queryParameters": {
      "serviceAgreementId": {
        "matches": "[\\w-]+"
      }
    }
  },
  "response": {
    "status": 200,
    "jsonBody": [
      {
        "id": "id",
        "name": "name"
      }
    ],
    "headers": {
      "Content-Type": "application/json"
    }
  }
}
